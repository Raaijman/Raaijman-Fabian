{
  "name": "@raaijman/raaijman-fabian",
  "version": "0.1.0",
  "private": true,
  "description": "fabian.raaijman.nl — persoonlijke CV-pagina als Nuxt 4-sibling van de Raaijman-familie.",
  "type": "module",
  "engines": {
    "node": ">=22",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "nuxt dev --port 3003",
    "build": "nuxt build",
    "start": "node .output/server/index.mjs",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "generate:pdf": "node scripts/generate-pdf.mjs",
    "build:ci": "nuxt build && node scripts/generate-pdf.mjs && nuxt build",
    "test:visual": "node scripts/compare-with-reference.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "nuxt typecheck"
  },
  "dependencies": {
    "@nuxt/ui": "^3.0.0",
    "nuxt": "^4.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@fontsource/eb-garamond": "^5.1.0",
    "@fontsource/public-sans": "^5.1.0",
    "@iconify-json/lucide": "^1.2.106",
    "@nuxt/eslint": "^0.7.0",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.0.0",
    "puppeteer": "^23.0.0",
    "typescript": "^5.5.0",
    "vue-tsc": "^2.1.0"
  }
}
