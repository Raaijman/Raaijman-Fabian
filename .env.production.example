# Productie env-template voor fabian.raaijman.nl.
# Concrete waardes worden in DA → Setup Node.js App → Environment variables gezet.

NUXT_PUBLIC_BASE_URL=https://fabian.raaijman.nl

# Optioneel — pas vullen als je later "ingelogd-als-Fabian"-state wilt detecteren
# uit de gedeelde .raaijman.nl-cookie. MOET dan identiek zijn met Raaijman-nl/
# Tourtoto/WK-toto.
NUXT_SESSION_PASSWORD=
NUXT_SESSION_COOKIE_DOMAIN=.raaijman.nl
